  m_Script: {fileID: 11500000, guid: a172a58da63188648bce5a20977bd940, type: 3}
  m_Name: DialogueSequenceProject
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  steps:
  - npcText: '"Hey ! Je cherche de l''inspiration pour mon prochain livre. Tu veux
      bien m''aider ?"'
    type: 0
    choices: []
    dataKey: project
  - npcText: '"..."'
    type: 1
    choices:
    - label: "Bien s\xFBr !"
      nextStepIndex: 2
    - label: T'aider ?
      nextStepIndex: 2
    dataKey: project
  - npcText: "\"D\xE9cris moi juste un de tes projets !\" "
    type: 2
    choices: []
    dataKey: project
  - npcText: '"Cool.... Et tu l''appellerais comment ?"'
    type: 2
    choices: []
    dataKey: project_title
  - npcText: "\"T'aimerais peut-\xEAtre me montrer une illustration ?\""
    type: 1
    choices:
    - label: Oui !
      nextStepIndex: 5
    - label: Non, merci !
      nextStepIndex: 7
    dataKey: project
  - npcText: '"..."'
    type: 3
    choices: []
    dataKey: project
  - npcText: '"Un autre illustration ?"'
    type: 1
    choices:
    - label: Oui !
      nextStepIndex: 5
    - label: Non merci !
      nextStepIndex: 7
    dataKey: project
  - npcText: '"Okay, merci pour ton aide !"'
    type: 0
    choices: []
    dataKey: project
